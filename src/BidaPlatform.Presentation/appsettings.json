{
  "ConnectionStrings": {
    "DefaultConnection": "__DB_CONNECTION__"
  },

  "Security": {
    "EncryptionKey": "__ENCRYPTION_KEY__"
  },

  "Jwt": {
    "Issuer": "BidaPlatform",
    "Audience": "BidaPlatform.Client",
    "SecretKey": "__JWT_SECRET__",
    "AccessTokenExpirationMinutes": 5,
    "RefreshTokenExpirationDays": 7
  },

  "Email": {
    "From": "no-reply@ecommerce.com",
    "FromName": "BidaPlatform System",
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "Username": "__EMAIL_USERNAME__",
    "Password": "__EMAIL_PASSWORD__"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  // IoT:Enabled = true  → BE gửi lệnh HTTP trực tiếp đến ESP8266 (chạy local cùng LAN quán)
  // IoT:Enabled = false → Bỏ qua điều khiển đèn, chỉ quản lý session (deploy cloud)
  "IoT": {
    "Enabled": true
  }

}
